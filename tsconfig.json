{
   "compilerOptions": {
      "target": "ES2022",
      "module": "ESNext",
      "lib": [
         "ESNext"
      ],
      "moduleResolution": "Bundler",
      "rootDir": "./src",
      "outDir": "./dist",
      "sourceMap": false,
      "inlineSources": false,
      "removeComments": true,
      "strict": true
   },
   "include": [
      "src/**/*.ts"
   ]
}